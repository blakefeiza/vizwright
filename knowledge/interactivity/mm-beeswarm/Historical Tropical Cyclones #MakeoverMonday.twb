      <aliases enabled='yes' />
      <column caption='Basin' datatype='string' name='[BASIN]' role='dimension' type='nominal'>
        <aliases>
          <alias key='%null%' value='Atlantic' />
          <alias key='&quot;EP&quot;' value='Eastern North Pacific' />
          <alias key='&quot;NI&quot;' value='North Indian' />
          <alias key='&quot;SA&quot;' value='South Atlantic' />
          <alias key='&quot;SI&quot;' value='South Indian' />
          <alias key='&quot;SP&quot;' value='Southern Pacific' />
          <alias key='&quot;WP&quot;' value='Western North Pacific' />
        </aliases>
      </column>
      <column aggregation='Sum' caption='Year' datatype='integer' name='[Calculation_0576234539573248]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATEPART(&apos;year&apos;, [ISO_TIME])' />
      </column>
      <column caption='Decade' datatype='string' name='[Calculation_0576234539634689]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEFT( STR([Calculation_0576234539573248]), 3) + &apos;0s&apos;' />
      </column>
      <column caption='Storms per Bin' datatype='integer' name='[Calculation_0576234541039619]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Storms per Bin&#10;{ FIXED [Year (bin)]: COUNTD([SID]) }' />
      </column>
      <column caption='Beeswarm' datatype='real' name='[Calculation_0576234541436933]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Beeswarm&#10;// CASE 1: If a bin has only 1 job, then plot them on Y=0&#10;IF ATTR([Calculation_0576234541039619]) = 1 THEN MIN(0)&#10;&#10;// CASE 2: If the bin has an odd number of records, then plot based on the record number in that bin&#10;ELSEIF ATTR([Calculation_0576234541039619])%2 = 1 &#10;THEN (&#10;    IF INDEX() = 1 THEN MIN(0) // Place the first on Y=0&#10;    ELSEIF INDEX()%2 = 0 THEN INDEX()*0.5 // Place even records in an odd bin above Y=0&#10;    ELSEIF INDEX()%2 = 1 THEN -(INDEX()-1)*0.5 // Place odd records in an odd bin below Y=0&#10;    END&#10;    )&#10;&#10;// CASE 3: If the bin has an even number of records, then plot them based on the record number in that bin&#10;ELSEIF ATTR([Calculation_0576234541039619])%2 = 0&#10;THEN (&#10;    IF INDEX() = 1 THEN 0.5  // Place the first on Y=0.5 (none in the middle)&#10;    ELSEIF INDEX()%2 = 0 THEN -INDEX()*0.5 + 0.5 // Place even records in an odd bin below Y=0&#10;    ELSEIF INDEX()%2 = 1 THEN INDEX()*0.5 // Place odd records in an odd bin above Y=0&#10;    END&#10;    )&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column aggregation='Sum' caption='Peak Intensity per SID' datatype='integer' name='[Calculation_0576234546122761]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{ FIXED [SID]: MAX([USA_SSHS]) }' />
      </column>
      <column caption='Start Date per SID' datatype='date' datatype-customized='true' default-format='*m/d' name='[Calculation_0576234548428812]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATE({ FIXED [SID]: MIN(DATETRUNC(&apos;day&apos;, [ISO_TIME])) })' />
      </column>
      <column caption='Duration (Days)' datatype='integer' name='[Calculation_0576234548781070]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [Calculation_0576234548428812], [Start Date per SID (copy)_0576234548686861])+1' />
      </column>
      <column caption='United States' datatype='string' name='[Calculation_0576234549755920]' role='dimension' semantic-role='[Country].[Name]' type='nominal'>
        <calculation class='tableau' formula='&apos;United States&apos;' />
      </column>
      <column caption='Dist2Land (Km)' datatype='integer' name='[DIST2LAND (KM)]' role='measure' type='quantitative' />
      <column caption='Iso Time' datatype='datetime' datatype-customized='true' name='[ISO_TIME]' role='dimension' type='ordinal' />
      <column caption='Landfall (Km)' datatype='integer' name='[LANDFALL (KM)]' role='measure' type='quantitative' />
      <column aggregation='Avg' datatype='real' name='[LAT]' role='measure' semantic-role='[Geographical].[Latitude]' type='quantitative' />
      <column aggregation='Avg' datatype='real' name='[LON]' role='measure' semantic-role='[Geographical].[Longitude]' type='quantitative' />
      <column caption='Name' datatype='string' name='[NAME]' role='dimension' type='nominal' />
      <column caption='Nature' datatype='string' name='[NATURE]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;DS&quot;' value='Disturbance' />
          <alias key='&quot;ET&quot;' value='Extratropical' />
          <alias key='&quot;MX&quot;' value='Mixture' />
          <alias key='&quot;NR&quot;' value='Not Reported' />
          <alias key='&quot;SS&quot;' value='Subtropical' />
          <alias key='&quot;TS&quot;' value='Tropical' />
        </aliases>
      </column>
