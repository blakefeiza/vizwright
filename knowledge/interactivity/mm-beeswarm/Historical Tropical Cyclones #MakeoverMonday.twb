      <column aggregation='None' caption='Year (bin)' datatype='integer' name='[Year (bin)]' role='dimension' type='quantitative'>
        <calculation class='bin' decimals='0' formula='[Calculation_0576234539573248]' peg='0' size-parameter='[Parameters].[Parameter 1]' />
