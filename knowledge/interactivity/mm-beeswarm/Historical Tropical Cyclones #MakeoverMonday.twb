      <column caption='End Date per SID' datatype='date' datatype-customized='true' default-format='*m/d' name='[Start Date per SID (copy)_0576234548686861]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATE({ FIXED [SID]: MAX(DATETRUNC(&apos;day&apos;, [ISO_TIME])) })' />
      </column>
