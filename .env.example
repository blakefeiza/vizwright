# Tableau Cloud credentials for the automated render loop (tools/publish_render.py)
# Copy to .env (gitignored) and fill in.
#
# Get a free dev site: https://developer.tableau.com -> Tableau Developer Program
# -> "Get my free developer site". Then in Tableau Cloud:
# Account Settings -> Personal Access Tokens -> create one.

# Your Tableau Cloud pod URL (browser address bar, before /#/site/...)
TABLEAU_SERVER_URL=https://10ax.online.tableau.com

# Site content URL: the part after /site/ in your browser URL
TABLEAU_SITE_ID=yoursitename

# Personal Access Token
TABLEAU_PAT_NAME=tig-agent
TABLEAU_PAT_SECRET=paste-secret-here
